{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "jsonata",
      "fileFormat": "json",
      "managerFilePatterns": ["/(^|/)package\\.json$/"],
      "matchStrings": [
        "($pm := $.devEngines.packageManager; $pm ? ( $isArr := $type($pm) = 'array'; $pmList := $isArr ? $pm : [$pm]; $pnpmObj := $pmList[name='pnpm']; $pnpmObj ? { 'currentValue': $pnpmObj.version, 'depName': 'pnpm', 'datasource': 'npm' } : null ) : null)",
        "($rt := $.devEngines.runtime; $rt ? ( $isArr := $type($rt) = 'array'; $rtList := $isArr ? $rt : [$rt]; $nodeObj := $rtList[name='node']; $nodeObj ? { 'currentValue': $nodeObj.version, 'depName': 'node', 'datasource': 'node-version' } : null ) : null)"
      ]
    }
  ],
  "extends": ["config:recommended", "schedule:weekly"],
  "ignoreDeps": ["preact"],
  "packageRules": [
    {
      "automerge": true,
      "automergeType": "pr",
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["minor", "patch"],
      "minimumReleaseAge": "1 days",
      "platformAutomerge": true
    },
    {
      "automerge": true,
      "automergeType": "pr",
      "matchDepNames": ["pnpm", "node"],
      "matchManagers": ["custom.jsonata"],
      "minimumReleaseAge": "1 days",
      "platformAutomerge": true
    },
    {
      "additionalBranchPrefix": "pnpm-",
      "groupName": "pnpm",
      "matchDepNames": ["pnpm"]
    },
    {
      "additionalBranchPrefix": "node-",
      "groupName": "node",
      "matchDepNames": ["node"]
    }
  ],
  "timezone": "Etc/UTC"
}
